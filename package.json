    "@shopify/storefront-api-client": "^1.0.4",
    "@supabase/supabase-js": "^2.45.4",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "^4.16.7",
    "class-variance-authority": "^0.7.0",
