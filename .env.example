# Copy to .env.local and fill with real values — NEVER commit .env.local
# Values are retrieved from the old repo or from Supabase/Shopify/Brevo dashboards.

# --- Supabase (existing project, do not recreate) ---
PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Shopify Storefront API ---
# Storefront token is 32 hex chars (NOT the shpat_ Admin token).
# Generated via Shopify Admin > Settings > Apps and sales channels > Develop apps > Storefront API.
PUBLIC_SHOPIFY_STOREFRONT_DOMAIN="ma-papeterie.myshopify.com"
PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN="<32-char-storefront-token>"

# --- Brevo (transactional email + newsletter) ---
BREVO_API_KEY="xkeysib-..."

# --- Site URL (switch to https://ma-papeterie.fr at D+16 cutover) ---
PUBLIC_SITE_URL="https://ma-papeterie-v1.netlify.app"
