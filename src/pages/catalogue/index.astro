---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CatalogueFilters from '@/components/catalogue/CatalogueFilters.astro';
import Pagination from '@/components/catalogue/Pagination.astro';
import ProductCard from '@/components/product/ProductCard.astro';
import SortSelect from '@/components/catalogue/SortSelect.astro';
import {
  CATALOGUE_PAGE_SIZE,
  fetchCatalogue,
  fetchDistinctBrands,
  fetchDistinctCategoryNames,
  type SortKey,
} from '@/lib/queries';
import { computeDisplayPrices, fetchPricingCoefficients, type DisplayPrice } from '@/lib/pricing';
import { breadcrumbSchema, itemListSchema } from '@/lib/schema';
import SemanticSuggestions from '@/components/catalogue/SemanticSuggestions';
import SearchTracker from '@/components/catalogue/SearchTracker.astro';

export const prerender = false;

const url = Astro.url;
const params = url.searchParams;

const allowedSorts: SortKey[] = ['pertinence', 'price-asc', 'price-desc', 'newest'];
const rawSort = params.get('sort');
const sort: SortKey = allowedSorts.includes(rawSort as SortKey)
  ? (rawSort as SortKey)
  : 'pertinence';

// Hard cap on the page param. The catalogue has ~3.5k displayable products at
// 24/page = ~146 pages — anything beyond 200 is junk traffic (scrapers, bots
// fuzzing pagination, ?page=999999 fingerprinters). Without this, large pages
// trigger a costly Supabase range scan + a 416 on filtered listings (see
// PHASE-2-FINDINGS.md). fetchCatalogue further clamps to totalPages, so this
// is just the first line of defense.
const PAGE_HARD_MAX = 200;
const pageParam = Number.parseInt(params.get('page') ?? '1', 10);
const page = Number.isFinite(pageParam) && pageParam > 0 ? Math.min(pageParam, PAGE_HARD_MAX) : 1;

const parsePositiveFloat = (raw: string | null): number | undefined => {
  if (!raw) return undefined;
  const v = Number.parseFloat(raw);
  return Number.isFinite(v) && v >= 0 ? v : undefined;
};

const categoryValues = params.getAll('category').filter((v) => v.length > 0);
const brandValues = params.getAll('brand').filter((v) => v.length > 0);

const filters = {
  category: categoryValues.length > 0 ? categoryValues : undefined,
  brand: brandValues.length > 0 ? brandValues : undefined,
  priceMin: parsePositiveFloat(params.get('priceMin')),
  priceMax: parsePositiveFloat(params.get('priceMax')),
  inStockOnly: params.get('inStock') === '1',
  search: params.get('q') ?? undefined,
};

let result: Awaited<ReturnType<typeof fetchCatalogue>> | null = null;
let fetchError: string | null = null;
let prices = new Map<string, DisplayPrice>();
try {
  const [res, coefs] = await Promise.all([
    fetchCatalogue({ ...filters, sort, page }),
    fetchPricingCoefficients(),
  ]);
  result = res;
  prices = computeDisplayPrices(res.items, coefs);
} catch (err) {
  fetchError = err instanceof Error ? err.message : 'Erreur catalogue';
}

const [categories, brands] = await Promise.all([
  fetchDistinctCategoryNames().catch(() => []),
  fetchDistinctBrands().catch(() => []),
]);

const baseParams: Array<[string, string]> = [];
for (const [k, v] of params.entries()) {
  if (k === 'page') continue;
  if (v) baseParams.push([k, v]);
}

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const jsonLd = [
  breadcrumbSchema([
    { name: 'Accueil', url: siteUrl },
    { name: 'Catalogue', url: `${siteUrl}/catalogue` },
  ]),
];

if (result && result.items.length > 0 && page === 1) {
  jsonLd.push(
    itemListSchema(
      result.items.map((p) => ({
        name: p.name,
        slug: p.slug ?? p.id,
        image_url: p.image_url,
        priceTTC: prices.get(p.id)?.ttc ?? p.price_ttc ?? p.price ?? 0,
        brand: p.brand ?? null,
      })),
      filters.search ? `Recherche : ${filters.search}` : 'Catalogue Ma Papeterie',
    ),
  );
}

const pageDescription = filters.search
  ? `Résultats pour « ${filters.search} » dans le catalogue Ma Papeterie.`
  : 'Parcourez plus de 20 000 références de fournitures bureau et scolaires. Retrait boutique à Chaumont ou livraison en France.';

const total = result?.total ?? 0;
const rangeStart = result && total > 0 ? (page - 1) * CATALOGUE_PAGE_SIZE + 1 : 0;
const rangeEnd = result ? Math.min(page * CATALOGUE_PAGE_SIZE, total) : 0;

// SEO: thin search-results / filter combinations get noindex. Only the bare
// /catalogue and pages with a single category filter (which has its own
// canonical /catalogue/<slug> anyway) keep the indexable status. Page > 1
// also noindex (paginated content has lower SEO value, see GSC guidance).
const hasMultiCategory = categoryValues.length > 1;
const hasBrand = brandValues.length > 0;
const hasPriceFilter = filters.priceMin !== undefined || filters.priceMax !== undefined;
const hasSearch = !!filters.search;
const hasInStock = filters.inStockOnly;
const isPaginated = page > 1;
const isFiltered =
  hasSearch || hasMultiCategory || hasBrand || hasPriceFilter || hasInStock || isPaginated;
---

<BaseLayout
  title={filters.search ? `Recherche : ${filters.search}` : 'Catalogue'}
  description={pageDescription}
  noindex={isFiltered}
  jsonLd={jsonLd}
>
  {filters.search && <SearchTracker query={filters.search} resultsCount={total} />}
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <nav aria-label="Fil d'Ariane" class="mb-6 text-xs text-primary/60">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-accent">Accueil</a></li>
        <li aria-hidden="true">/</li>
        <li class="text-primary" aria-current="page">Catalogue</li>
      </ol>
    </nav>

    <header class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-display text-3xl font-semibold text-primary sm:text-4xl">
          {filters.search ? `Recherche : « ${filters.search} »` : 'Catalogue'}
        </h1>
        {
          result && !fetchError && (
            <p class="mt-2 text-sm text-primary/60">
              {total === 0
                ? 'Aucun produit ne correspond à vos critères.'
                : `Produits ${rangeStart}–${rangeEnd} sur ~${total.toLocaleString('fr-FR')}`}
            </p>
          )
        }
      </div>
      <SortSelect sort={sort} baseParams={baseParams} />
    </header>

    <div class="grid gap-8 md:grid-cols-[260px_1fr]">
      <aside>
        <CatalogueFilters categories={categories} brands={brands} selected={{ ...filters, sort }} />
      </aside>

      <div>
        {
          fetchError && (
            <div class="rounded-card border border-danger/30 bg-danger/5 p-6 text-sm text-danger">
              Impossible de charger le catalogue&nbsp;: {fetchError}
            </div>
          )
        }

        {
          result && result.items.length === 0 && !fetchError && (
            <div class="rounded-card border border-primary/10 bg-white p-8 sm:p-12">
              <div class="mx-auto flex max-w-xl flex-col items-center text-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="48"
                  height="48"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="text-primary/30"
                  aria-hidden="true"
                >
                  <circle cx="11" cy="11" r="8" />
                  <path d="m21 21-4.3-4.3" />
                </svg>
                <p class="mt-4 font-display text-xl font-semibold text-primary">
                  {filters.search ? `Aucun résultat pour « ${filters.search} »` : 'Aucun résultat'}
                </p>
                <p class="mt-2 text-sm text-primary/60">
                  {filters.search
                    ? "Vérifiez l'orthographe ou essayez un terme plus large. Notre boutique référence plus de 20 000 produits — contactez-nous si vous ne trouvez pas votre article."
                    : 'Essayez avec moins de filtres ou un autre mot-clé.'}
                </p>
                <div class="mt-6 flex flex-wrap justify-center gap-3">
                  <a
                    href="/catalogue"
                    class="inline-flex h-11 items-center rounded-btn bg-primary px-4 text-sm font-medium text-white hover:bg-primary/90"
                  >
                    {filters.search ? 'Voir tout le catalogue' : 'Réinitialiser les filtres'}
                  </a>
                  <a
                    href={`/devis${filters.search ? `?recherche=${encodeURIComponent(filters.search)}` : ''}`}
                    class="inline-flex h-11 items-center rounded-btn border border-primary/15 bg-white px-4 text-sm font-medium text-primary hover:border-accent hover:text-accent"
                  >
                    Demander un devis
                  </a>
                  <a
                    href="/contact"
                    class="inline-flex h-11 items-center rounded-btn border border-primary/15 bg-white px-4 text-sm font-medium text-primary hover:border-accent hover:text-accent"
                  >
                    Nous contacter
                  </a>
                </div>
              </div>
              {filters.search && filters.search.length >= 3 && (
                <SemanticSuggestions client:idle query={filters.search} />
              )}
            </div>
          )
        }

        {
          result && result.items.length > 0 && (
            <>
              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
                {result.items.map((product, idx) => (
                  <ProductCard
                    product={product}
                    prices={prices.get(product.id)}
                    priority={idx < 8}
                  />
                ))}
              </div>
              <Pagination
                page={result.page}
                totalPages={result.totalPages}
                baseParams={baseParams}
              />
            </>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
