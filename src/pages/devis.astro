---
import BaseLayout from '@/layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout
  title="Devis B2B - Fournitures bureau entreprises & collectivités - Ma Papeterie Chaumont"
  description="Demandez un devis personnalisé pour vos fournitures de bureau. Ma Papeterie sert les entreprises, écoles et collectivités de Haute-Marne. Réponse sous 24h."
  canonical="https://ma-papeterie-v1.netlify.app/devis"
>
  <!-- Hero -->
  <section class="border-b border-primary/5 bg-bg-soft">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8">
      <span class="label-category">Entreprises · Écoles · Collectivités</span>
      <h1 class="mt-4 font-display text-4xl font-semibold text-primary sm:text-5xl">
        Fournitures B2B&nbsp;:<br />
        <span class="text-accent">devis sous 24&nbsp;h</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-primary/70">
        Vous gérez les achats d'une entreprise, d'un établissement scolaire ou d'une collectivité
        en Haute-Marne&nbsp;? On vous établit un devis sur mesure, livrable directement ou en
        retrait boutique à Chaumont.
      </p>
      <div class="mt-8">
        <a
          href="#formulaire-devis"
          class="inline-flex h-12 items-center rounded-btn bg-accent px-8 text-sm font-medium text-white hover:bg-accent-hover"
        >
          Demander un devis
        </a>
      </div>
    </div>
  </section>

  <!-- Avantages B2B -->
  <section class="border-b border-primary/5 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-display text-2xl font-semibold text-primary sm:text-3xl">
        Pourquoi commander en B2B chez nous&nbsp;?
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">📋</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Devis personnalisé</h3>
          <p class="mt-1 text-sm text-primary/60">
            Envoyez votre liste ou vos besoins. On vous retourne un devis détaillé, article par
            article, avec les remises applicables.
          </p>
        </div>
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">💳</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Facturation 30 jours</h3>
          <p class="mt-1 text-sm text-primary/60">
            Paiement à 30 jours fin de mois pour les clients professionnels avec compte ouvert.
            Bon de commande accepté.
          </p>
        </div>
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">🚚</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Livraison Haute-Marne</h3>
          <p class="mt-1 text-sm text-primary/60">
            Livraison dans vos locaux ou retrait gratuit en boutique. Tournées régulières sur Chaumont
            et environs.
          </p>
        </div>
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">🏷️</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Tarifs HT négociés</h3>
          <p class="mt-1 text-sm text-primary/60">
            Grille tarifaire B2B à partir de 10 articles. Plus la commande est importante,
            plus les remises sont significatives.
          </p>
        </div>
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">🔁</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Réapprovisionnement</h3>
          <p class="mt-1 text-sm text-primary/60">
            Commandes récurrentes simplifiées. Votre historique est conservé pour renouveler
            en un envoi d'email.
          </p>
        </div>
        <div class="rounded-card bg-bg-soft p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">🤝</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Interlocuteur dédié</h3>
          <p class="mt-1 text-sm text-primary/60">
            Un référent unique pour vos commandes. Pas de chatbot, pas de formulaire en boucle.
            Un humain qui connaît votre dossier.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Secteurs -->
  <section class="border-b border-primary/5 bg-bg-soft py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-display text-2xl font-semibold text-primary sm:text-3xl">
        Nous servons déjà
      </h2>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        {[
          'PME & artisans',
          'Cabinets médicaux',
          'Études notariales',
          'Établissements scolaires',
          'Communes & collectivités',
          'Associations',
          'Professions libérales',
          'Agences immobilières',
        ].map((secteur) => (
          <span class="label-category">{secteur}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Formulaire devis -->
  <section id="formulaire-devis" class="py-16 sm:py-20">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="label-category">Réponse sous 24h ouvrées</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-primary sm:text-3xl">
          Demandez votre devis
        </h2>
        <p class="mt-3 text-primary/60">
          Remplissez ce formulaire ou envoyez directement votre liste à
          <a href="mailto:contact@ma-papeterie.fr" class="text-accent hover:underline">
            contact@ma-papeterie.fr
          </a>.
        </p>
      </div>

      <form
        name="devis-b2b"
        method="POST"
        action="/devis?success=1"
        class="mt-10 space-y-5 rounded-card bg-bg-soft p-8 shadow-card"
        aria-label="Formulaire demande de devis B2B"
      >
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="nom" class="block text-sm font-medium text-primary">
              Nom <span aria-hidden="true">*</span>
            </label>
            <input
              id="nom"
              name="nom"
              type="text"
              required
              autocomplete="family-name"
              class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
              placeholder="Dupont"
            />
          </div>
          <div>
            <label for="prenom" class="block text-sm font-medium text-primary">
              Prénom <span aria-hidden="true">*</span>
            </label>
            <input
              id="prenom"
              name="prenom"
              type="text"
              required
              autocomplete="given-name"
              class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
              placeholder="Jean"
            />
          </div>
        </div>

        <div>
          <label for="societe" class="block text-sm font-medium text-primary">
            Société / Organisme <span aria-hidden="true">*</span>
          </label>
          <input
            id="societe"
            name="societe"
            type="text"
            required
            autocomplete="organization"
            class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
            placeholder="SARL Dupont ou Mairie de Chaumont"
          />
        </div>

        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="email" class="block text-sm font-medium text-primary">
              Email <span aria-hidden="true">*</span>
            </label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
              placeholder="jean@societe.fr"
            />
          </div>
          <div>
            <label for="telephone" class="block text-sm font-medium text-primary">
              Téléphone
            </label>
            <input
              id="telephone"
              name="telephone"
              type="tel"
              autocomplete="tel"
              class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
              placeholder="03 25 XX XX XX"
            />
          </div>
        </div>

        <div>
          <label for="besoin" class="block text-sm font-medium text-primary">
            Décrivez votre besoin <span aria-hidden="true">*</span>
          </label>
          <textarea
            id="besoin"
            name="besoin"
            required
            rows={5}
            class="mt-1.5 w-full rounded-btn border border-primary/15 bg-white px-3 py-2.5 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
            placeholder="Ex : 20 ramettes de papier A4 80g, 50 stylos bille bleus, 10 classeurs A4... Ou joignez votre liste par email."
          ></textarea>
        </div>

        <div>
          <label for="budget" class="block text-sm font-medium text-primary">
            Budget estimé HT
          </label>
          <select
            id="budget"
            name="budget"
            class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
          >
            <option value="">-- Optionnel --</option>
            <option>Moins de 200 €</option>
            <option>200 – 500 €</option>
            <option>500 – 2 000 €</option>
            <option>2 000 – 5 000 €</option>
            <option>Plus de 5 000 €</option>
          </select>
        </div>

        <button
          type="submit"
          class="h-12 w-full rounded-btn bg-accent text-sm font-medium text-white hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-accent/50"
        >
          Envoyer ma demande de devis
        </button>

        <p class="text-center text-xs text-primary/40">
          Réponse sous 24h ouvrées. Données utilisées uniquement pour traiter votre demande.
        </p>
      </form>
    </div>
  </section>

  <!-- JSON-LD Service B2B -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Fournitures de bureau B2B — Ma Papeterie Chaumont",
    "description": "Devis personnalisé pour fournitures de bureau, scolaires et papeterie. Livraison en Haute-Marne ou retrait boutique Chaumont.",
    "provider": {
      "@type": "OfficeEquipmentStore",
      "name": "Ma Papeterie — Reine & Fils",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "10 rue Toupot de Béveaux",
        "postalCode": "52000",
        "addressLocality": "Chaumont",
        "addressRegion": "Haute-Marne",
        "addressCountry": "FR"
      }
    },
    "areaServed": {
      "@type": "AdministrativeArea",
      "name": "Haute-Marne"
    },
    "serviceType": "Fournitures de bureau B2B",
    "audience": {
      "@type": "Audience",
      "audienceType": "Entreprises, collectivités, établissements scolaires"
    }
  })} />
</BaseLayout>
