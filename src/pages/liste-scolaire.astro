---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SchoolListMatcher from '@/components/school-list/SchoolListMatcher';

export const prerender = true;
---

<BaseLayout
  title="Listes scolaires 2026-2027 - Ma Papeterie Chaumont"
  description="Uploadez la liste scolaire de votre enfant, nous préparons le sac complet. Retrait boutique Chaumont ou livraison Haute-Marne. Service bientôt disponible, inscrivez-vous."
  canonical="https://ma-papeterie-v1.netlify.app/liste-scolaire"
>
  <!-- Banner feedback formulaire -->
  <div id="form-banner-ls"></div>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var params = new URLSearchParams(window.location.search);
      var banner = document.getElementById('form-banner-ls');
      if (!banner) return;
      var msg = '';
      var color = '';
      if (params.get('merci') === '1') {
        msg =
          'Merci\u00a0! Vous serez pr\u00e9venu\u00b7e d\u00e8s l\u2019ouverture du service en juillet 2026.';
        color = 'green';
      } else if (params.get('erreur') === 'email') {
        msg = 'Email invalide, merci de v\u00e9rifier votre adresse.';
        color = 'orange';
      } else if (params.get('erreur')) {
        msg = 'Une erreur est survenue. R\u00e9essayez ou contactez-nous.';
        color = 'red';
      }
      if (!msg) return;
      var cls = {
        green: 'bg-green-50 border-green-200 text-green-800',
        orange: 'bg-orange-50 border-orange-200 text-orange-800',
        red: 'bg-red-50 border-red-200 text-red-800',
      };
      banner.className = 'mx-auto max-w-7xl px-4 pt-6 sm:px-6 lg:px-8';
      var inner = document.createElement('div');
      inner.setAttribute('role', 'alert');
      inner.className = 'rounded-btn border px-4 py-3 text-sm ' + cls[color];
      inner.textContent = msg;
      banner.appendChild(inner);
    });
  </script>

  <!-- Hero -->
  <section class="border-b border-primary/5 bg-bg-soft">
    <div class="mx-auto max-w-4xl px-4 py-16 text-center sm:px-6 sm:py-24 lg:px-8">
      <span class="label-category">Service expérimental · Disponible dès maintenant</span>
      <h1 class="mt-4 font-display text-4xl font-semibold text-primary sm:text-5xl">
        Listes scolaires&nbsp;: on cherche,<br />
        <span class="text-accent">vous validez</span>
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-primary/70">
        Collez la liste de fournitures de votre enfant ci-dessous. On vous propose les produits
        correspondants dans notre catalogue, vous validez et ajoutez tout au panier en un clic.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href="#matcher"
          class="inline-flex h-12 items-center rounded-btn bg-accent px-8 text-sm font-medium text-white hover:bg-accent-hover"
        >
          Tester maintenant
        </a>
        <a
          href="#inscription"
          class="inline-flex h-12 items-center rounded-btn border border-primary/15 bg-white px-8 text-sm font-medium text-primary hover:bg-bg-soft"
        >
          Service rentrée 2026–2027
        </a>
      </div>
    </div>
  </section>

  <!-- Matcher live -->
  <section id="matcher" class="border-b border-primary/5 py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="label-category">Étape 1</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-primary sm:text-3xl">
          Collez votre liste, on cherche les produits
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-primary/60">
          Une ligne par article. La quantité peut être indiquée au début (ex&nbsp;: «&nbsp;12 stylos
          bille bleu&nbsp;»).
        </p>
      </div>
      <div class="mt-8 rounded-card bg-white p-6 shadow-card">
        <SchoolListMatcher client:load />
      </div>
    </div>
  </section>

  <!-- Comment ça marche -->
  <section class="border-b border-primary/5 py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-display text-2xl font-semibold text-primary sm:text-3xl">
        Comment ça marche&nbsp;?
      </h2>
      <p class="mx-auto mt-3 max-w-xl text-center text-primary/60">Trois étapes, zéro stress.</p>
      <div class="mt-12 grid gap-8 sm:grid-cols-3">
        <div class="flex flex-col items-center text-center">
          <div
            class="flex h-14 w-14 items-center justify-center rounded-full bg-accent/10 text-accent"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="17 8 12 3 7 8"></polyline>
              <line x1="12" y1="3" x2="12" y2="15"></line>
            </svg>
          </div>
          <span class="mt-4 text-xs font-semibold uppercase tracking-wider text-accent"
            >Étape 1</span
          >
          <h3 class="mt-2 font-display text-lg font-semibold text-primary">Uploadez la liste</h3>
          <p class="mt-2 text-sm text-primary/60">
            Déposez la liste fournie par l'établissement (PDF, photo ou fichier). On accepte tous
            les formats.
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div
            class="flex h-14 w-14 items-center justify-center rounded-full bg-accent/10 text-accent"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
              <path d="M3 6h18"></path>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
          </div>
          <span class="mt-4 text-xs font-semibold uppercase tracking-wider text-accent"
            >Étape 2</span
          >
          <h3 class="mt-2 font-display text-lg font-semibold text-primary">On prépare le kit</h3>
          <p class="mt-2 text-sm text-primary/60">
            Notre équipe sélectionne chaque article, vérifie les spécifications et emballe le tout
            soigneusement sous 48&nbsp;h.
          </p>
        </div>

        <div class="flex flex-col items-center text-center">
          <div
            class="flex h-14 w-14 items-center justify-center rounded-full bg-accent/10 text-accent"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
          </div>
          <span class="mt-4 text-xs font-semibold uppercase tracking-wider text-accent"
            >Étape 3</span
          >
          <h3 class="mt-2 font-display text-lg font-semibold text-primary">Vous récupérez</h3>
          <p class="mt-2 text-sm text-primary/60">
            Retrait gratuit en boutique rue Toupot de Béveaux à Chaumont, ou livraison à domicile en
            Haute-Marne.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Bénéfices -->
  <section class="border-b border-primary/5 bg-bg-soft py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-center font-display text-2xl font-semibold text-primary sm:text-3xl">
        Pourquoi choisir ce service&nbsp;?
      </h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-card bg-white p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">⏱️</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Gain de temps</h3>
          <p class="mt-1 text-sm text-primary/60">
            Fini les courses dans plusieurs enseignes. Tout est prêt en une commande.
          </p>
        </div>
        <div class="rounded-card bg-white p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">✅</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Qualité garantie</h3>
          <p class="mt-1 text-sm text-primary/60">
            Marques Bic, Clairefontaine, Stabilo, Maped… Les mêmes que celles demandées par les
            profs.
          </p>
        </div>
        <div class="rounded-card bg-white p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">💶</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Prix justes</h3>
          <p class="mt-1 text-sm text-primary/60">
            Tarifs boutique, sans majoration de service. Même prix qu'en rayon.
          </p>
        </div>
        <div class="rounded-card bg-white p-6 shadow-card">
          <span class="text-2xl" aria-hidden="true">🏪</span>
          <h3 class="mt-3 font-display text-base font-semibold text-primary">Retrait facile</h3>
          <p class="mt-1 text-sm text-primary/60">
            Boutique ouverte lundi–samedi 9h–18h. Créneau réservé à la rentrée pour éviter les
            files.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Formulaire d'inscription -->
  <section id="inscription" class="py-16 sm:py-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <span class="label-category">Saison rentrée 2026–2027</span>
        <h2 class="mt-3 font-display text-2xl font-semibold text-primary sm:text-3xl">
          Service complet&nbsp;: on prépare le kit pour vous
        </h2>
        <p class="mt-3 text-primary/60">
          À partir de juillet 2026, on prend en charge la préparation complète du kit (sélection,
          emballage, créneau retrait prioritaire). Laissez votre email pour être prévenu à
          l'ouverture.
        </p>
      </div>

      <form
        name="liste-scolaire-inscription"
        method="POST"
        action="/api/inscription-liste-scolaire"
        class="mt-10 space-y-5 rounded-card bg-bg-soft p-8 shadow-card"
        aria-label="Formulaire d'inscription liste scolaire"
      >
        <div>
          <label for="prenom" class="block text-sm font-medium text-primary">
            Prénom <span aria-hidden="true">*</span>
          </label>
          <input
            id="prenom"
            name="prenom"
            type="text"
            required
            autocomplete="given-name"
            class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
            placeholder="Marie"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-primary">
            Email <span aria-hidden="true">*</span>
          </label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary placeholder:text-primary/40 focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
            placeholder="marie@exemple.fr"
          />
        </div>

        <div>
          <label for="niveau" class="block text-sm font-medium text-primary">
            Niveau de votre enfant
          </label>
          <select
            id="niveau"
            name="niveau"
            class="mt-1.5 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
          >
            <option value="">-- Sélectionner --</option>
            <option>CP</option>
            <option>CE1</option>
            <option>CE2</option>
            <option>CM1</option>
            <option>CM2</option>
            <option>6e</option>
            <option>5e</option>
            <option>4e</option>
            <option>3e</option>
            <option>2nde</option>
            <option>1re</option>
            <option>Terminale</option>
            <option>BTS / Supérieur</option>
          </select>
        </div>

        <button
          type="submit"
          class="h-12 w-full rounded-btn bg-accent text-sm font-medium text-white hover:bg-accent-hover focus:outline-none focus:ring-2 focus:ring-accent/50"
        >
          Me prévenir à l'ouverture
        </button>

        <p class="text-center text-xs text-primary/40">
          Pas de spam. Désinscription en 1 clic. Données non cédées.
        </p>
      </form>
    </div>
  </section>

  <!-- JSON-LD Service -->
  <script
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Service',
      name: 'Service listes scolaires Ma Papeterie Chaumont',
      description:
        'Préparation de kits de fournitures scolaires sur liste. Retrait boutique Chaumont ou livraison Haute-Marne.',
      provider: {
        '@type': 'OfficeEquipmentStore',
        name: 'Ma Papeterie — Reine & Fils',
        address: {
          '@type': 'PostalAddress',
          streetAddress: '10 rue Toupot de Béveaux',
          postalCode: '52000',
          addressLocality: 'Chaumont',
          addressRegion: 'Haute-Marne',
          addressCountry: 'FR',
        },
      },
      areaServed: {
        '@type': 'AdministrativeArea',
        name: 'Haute-Marne',
      },
      serviceType: 'Préparation listes scolaires',
    })}
  />
</BaseLayout>
