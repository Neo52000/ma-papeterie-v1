---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSlider from '@/components/home/HeroSlider';
import TrustStripV5 from '@/components/home/TrustStripV5.astro';
import CategoryUniversGridV5 from '@/components/home/CategoryUniversGridV5.astro';
import PromoBlocksV5 from '@/components/home/PromoBlocksV5.astro';
import B2bCalloutV5 from '@/components/home/B2bCalloutV5.astro';
import TestimonialsV5 from '@/components/home/TestimonialsV5';
import NewsletterCardV5 from '@/components/home/NewsletterCardV5.astro';
import ConseilsCardsV5 from '@/components/home/ConseilsCardsV5.astro';
import SeoTextBlockV5 from '@/components/home/SeoTextBlockV5.astro';
import FindUsCardV5 from '@/components/home/FindUsCardV5.astro';
import ProductCard from '@/components/product/ProductCard.astro';
import RecentlyViewedSection from '@/components/product/RecentlyViewedSection';
import { heroSlides } from '@/data/heroSlides';
import { fetchCatalogue } from '@/lib/queries';
import { computeDisplayPrices, fetchPricingCoefficients, type DisplayPrice } from '@/lib/pricing';
import { websiteSchema } from '@/lib/schema';
import { supabaseServer } from '@/lib/supabase';
import type { Product } from '@/types/database';

// SSR: featured products are refreshed on each request (stock + nouveautés).
export const prerender = false;

let featured: Product[] = [];
let prices = new Map<string, DisplayPrice>();
let featuredError: string | null = null;
let displayableCount: number | null = null;
try {
  const [res, coefs, countRes] = await Promise.all([
    fetchCatalogue({ sort: 'newest', inStockOnly: true }),
    fetchPricingCoefficients(),
    supabaseServer.rpc('count_displayable_products'),
  ]);
  featured = res.items.slice(0, 4);
  prices = computeDisplayPrices(featured, coefs);
  if (!countRes.error && countRes.data != null) {
    displayableCount = Number(countRes.data);
  }
} catch (err) {
  featuredError = err instanceof Error ? err.message : 'Supabase unavailable';
}

// Round to the nearest 500 for a stable user-facing figure (real count
// drifts every nightly Comlandi sync — showing 11 547 → 11 562 → 11 580
// looks unprofessional). Falls back to a literal when RPC fails.
const displayableLabel =
  displayableCount != null
    ? `${(Math.floor(displayableCount / 500) * 500).toLocaleString('fr-FR')}+`
    : '11 000+';
---

<BaseLayout
  title="Ma Papeterie — Reine & Fils · Chaumont (52)"
  description={`Papeterie, fournitures de bureau & scolaires à Chaumont. Boutique physique + livraison partout en France. Devis B2B, listes scolaires, ${displayableLabel} références en ligne.`}
  jsonLd={[websiteSchema()]}
>
  <!-- a11y: page heading. Hidden visually because the visual hierarchy
       starts with the hero slider (h2), but every page needs exactly one
       h1 for screen readers and SEO. -->
  <h1 class="sr-only">
    Ma Papeterie — Reine &amp; Fils, papeterie et fournitures de bureau à Chaumont (52)
  </h1>

  <!-- 1. Hero slider -->
  <section class="bg-bg-soft py-6 sm:py-8" aria-label="Mises en avant">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <HeroSlider client:visible slides={heroSlides} />
    </div>
  </section>

  <!-- 2. Trust strip (4 garanties) -->
  <TrustStripV5 />

  <!-- 3. Explorez nos univers -->
  <CategoryUniversGridV5 />

  <!-- 4. Indispensables du moment -->
  {
    featured.length > 0 && (
      <section class="bg-bg-soft pb-14" aria-label="Indispensables du moment">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between gap-4">
            <div>
              <h2 class="font-display text-3xl font-semibold text-primary sm:text-4xl">
                Les indispensables du moment
              </h2>
              <p class="mt-2 text-sm text-primary/70">
                Les favoris de nos clients entreprises et particuliers.
              </p>
            </div>
            <a
              href="/catalogue"
              class="hidden items-center gap-1 text-sm font-medium text-primary hover:text-accent-dark sm:inline-flex"
            >
              Voir tout le catalogue <span aria-hidden="true">→</span>
            </a>
          </div>
          <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {featured.map((product, idx) => (
              <ProductCard product={product} prices={prices.get(product.id)} priority={idx < 4} />
            ))}
          </div>
        </div>
      </section>
    )
  }

  {
    featuredError && (
      <section class="mx-auto max-w-7xl px-4 pb-14 sm:px-6 lg:px-8">
        <div class="rounded-card border border-danger/30 bg-danger/5 p-6 text-sm text-danger">
          Catalogue temporairement indisponible&nbsp;: {featuredError}. Réessayez dans un instant.
        </div>
      </section>
    )
  }

  <!-- 5. Promotions du moment (2 blocs) -->
  <PromoBlocksV5 />

  <!-- 6. B2B callout + mini formulaire devis -->
  <B2bCalloutV5 />

  <!-- 7. Témoignages -->
  <TestimonialsV5
    client:visible
    testimonials={[
      {
        id: 'cned-leclerc',
        rating: 5,
        quote:
          'Partenaire stratégique depuis 5 ans. Fiabilité d’approvisionnement, innovations de service, dialogue permanent… Ma Papeterie comprend les enjeux de la pédagogie.',
        author: 'Jean-Pierre Leclerc',
        role: 'Responsable Approvisionnement, CNED',
        date: 'Novembre 2025',
      },
    ]}
  />

  <!-- 8. Newsletter -->
  <NewsletterCardV5 source="footer" />

  <!-- 9. Conseils & guides -->
  <ConseilsCardsV5 />

  <!-- 10. Recently viewed (legacy V1 — pertinent garder) -->
  <section class="mx-auto max-w-7xl px-4 pb-14 sm:px-6 lg:px-8">
    <RecentlyViewedSection client:idle currentProductId="" />
  </section>

  <!-- 11. SEO long-form -->
  <SeoTextBlockV5 />

  <!-- 12. Nous trouver -->
  <FindUsCardV5 />
</BaseLayout>
