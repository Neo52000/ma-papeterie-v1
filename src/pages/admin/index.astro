---
import AdminLayout from '@/layouts/AdminLayout.astro';
import AdminDashboard from '@/components/admin/AdminDashboard';

// Auth gating happens client-side (Supabase JS v2 stores sessions in
// localStorage, not cookies — SSR has no access). The React island
// `<AdminGuard>` wrapper checks session + admin role, redirects on miss.
export const prerender = true;
---

<AdminLayout title="Dashboard">
  <div class="mb-6">
    <h1 class="font-display text-2xl font-semibold text-primary">Dashboard</h1>
    <p class="mt-1 text-sm text-primary/60">État opérationnel en temps réel.</p>
  </div>

  <AdminDashboard client:only="react" />
</AdminLayout>
