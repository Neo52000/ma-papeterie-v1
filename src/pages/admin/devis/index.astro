---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdminFromCookie } from '@/lib/admin';
import { supabaseServer } from '@/lib/supabase';

export const prerender = false;

const gate = await requireAdminFromCookie(Astro);
if (gate instanceof Response) return gate;
const { email } = gate;

const allowedStatuses = ['pending', 'in_progress', 'answered', 'archived'] as const;
type Status = (typeof allowedStatuses)[number];

const url = Astro.url;
const rawStatus = url.searchParams.get('status') ?? 'pending';
const status: Status | 'all' = allowedStatuses.includes(rawStatus as Status)
  ? (rawStatus as Status)
  : rawStatus === 'all'
    ? 'all'
    : 'pending';

let query = supabaseServer
  .from('b2b_quotes')
  .select('id, created_at, company_name, contact_name, email, phone, message, status')
  .order('created_at', { ascending: false })
  .limit(200);

if (status !== 'all') {
  query = query.eq('status', status);
}

const { data, error } = await query;
const rows = (data ?? []) as Array<{
  id: string;
  created_at: string;
  company_name: string;
  contact_name: string;
  email: string;
  phone: string | null;
  message: string;
  status: Status;
}>;

const dateFmt = new Intl.DateTimeFormat('fr-FR', { dateStyle: 'short', timeStyle: 'short' });

const statusLabels: Record<Status, string> = {
  pending: 'En attente',
  in_progress: 'En cours',
  answered: 'Répondu',
  archived: 'Archivé',
};

const statusClasses: Record<Status, string> = {
  pending: 'bg-accent/10 text-accent',
  in_progress: 'bg-blue-50 text-blue-700',
  answered: 'bg-green-50 text-green-700',
  archived: 'bg-primary/5 text-primary/50',
};

const filterTabs = [
  { value: 'pending', label: 'En attente' },
  { value: 'in_progress', label: 'En cours' },
  { value: 'answered', label: 'Répondu' },
  { value: 'archived', label: 'Archivé' },
  { value: 'all', label: 'Tous' },
];
---

<AdminLayout title="Devis B2B" email={email}>
  <div class="mb-6 flex flex-wrap items-end justify-between gap-3">
    <div>
      <h1 class="font-display text-2xl font-semibold text-primary">Devis B2B</h1>
      <p class="mt-1 text-sm text-primary/60">
        {rows.length} résultat{rows.length > 1 ? 's' : ''}
        {error ? ' (erreur DB — voir détail dans la table)' : ''}
      </p>
    </div>
  </div>

  <nav
    aria-label="Filtre par statut"
    class="mb-4 flex flex-wrap gap-2 border-b border-primary/10 pb-3"
  >
    {
      filterTabs.map((tab) => (
        <a
          href={`/admin/devis?status=${tab.value}`}
          aria-current={status === tab.value ? 'page' : undefined}
          class:list={[
            'inline-flex h-8 items-center rounded-btn px-3 text-xs font-medium transition-colors',
            status === tab.value
              ? 'bg-primary text-white'
              : 'border border-primary/15 text-primary/70 hover:border-accent/50',
          ]}
        >
          {tab.label}
        </a>
      ))
    }
  </nav>

  {
    error && (
      <div class="rounded-card border border-danger/30 bg-danger/5 p-4 text-sm text-danger">
        Erreur Supabase : {error.message}
      </div>
    )
  }

  {
    rows.length === 0 && !error && (
      <div class="rounded-card border border-primary/10 bg-white p-12 text-center text-sm text-primary/60">
        Aucun devis avec ce statut.
      </div>
    )
  }

  {
    rows.length > 0 && (
      <div class="overflow-x-auto rounded-card border border-primary/10 bg-white shadow-card">
        <table class="min-w-full divide-y divide-primary/10 text-sm">
          <thead class="bg-bg-soft">
            <tr>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-primary/60">
                Date
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-primary/60">
                Société
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-primary/60">
                Contact
              </th>
              <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wider text-primary/60">
                Statut
              </th>
              <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wider text-primary/60">
                Action
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-primary/5 bg-white">
            {rows.map((row) => (
              <tr class="hover:bg-bg-soft/50">
                <td class="px-4 py-3 text-xs text-primary/60">
                  {dateFmt.format(new Date(row.created_at))}
                </td>
                <td class="px-4 py-3">
                  <p class="font-medium text-primary">{row.company_name}</p>
                </td>
                <td class="px-4 py-3 text-xs">
                  <p class="text-primary">{row.contact_name}</p>
                  <p class="text-primary/60">{row.email}</p>
                  {row.phone && <p class="text-primary/60">{row.phone}</p>}
                </td>
                <td class="px-4 py-3">
                  <span
                    class:list={[
                      'inline-flex items-center rounded-badge px-2 py-0.5 text-xs font-medium',
                      statusClasses[row.status],
                    ]}
                  >
                    {statusLabels[row.status]}
                  </span>
                </td>
                <td class="px-4 py-3 text-right">
                  <a
                    href={`/admin/devis/${row.id}`}
                    class="inline-flex h-8 items-center rounded-btn border border-primary/15 px-3 text-xs font-medium text-primary hover:border-accent hover:text-accent"
                  >
                    Détail →
                  </a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )
  }
</AdminLayout>
