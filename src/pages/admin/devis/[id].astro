---
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdminFromCookie } from '@/lib/admin';
import { supabaseServer } from '@/lib/supabase';

export const prerender = false;

const gate = await requireAdminFromCookie(Astro);
if (gate instanceof Response) return gate;
const { email } = gate;

const { id } = Astro.params;
if (!id) return Astro.redirect('/admin/devis', 302);

const { data, error } = await supabaseServer
  .from('b2b_quotes')
  .select(
    'id, created_at, updated_at, company_name, siret, contact_name, email, phone, message, attachment_url, status, source',
  )
  .eq('id', id)
  .maybeSingle();

if (error) {
  return new Response(`Erreur DB : ${error.message}`, { status: 500 });
}
if (!data) {
  return Astro.redirect('/admin/devis', 302);
}

const quote = data;
const dateFmt = new Intl.DateTimeFormat('fr-FR', { dateStyle: 'long', timeStyle: 'short' });

const allowedStatuses = ['pending', 'in_progress', 'answered', 'archived'] as const;
const statusLabels: Record<(typeof allowedStatuses)[number], string> = {
  pending: 'En attente',
  in_progress: 'En cours',
  answered: 'Répondu',
  archived: 'Archivé',
};

const url = Astro.url;
const updated = url.searchParams.get('updated') === '1';
const errParam = url.searchParams.get('erreur');
---

<AdminLayout title={`Devis ${quote.company_name}`} email={email}>
  <nav aria-label="Fil d'Ariane" class="mb-4 text-xs text-primary/60">
    <ol class="flex items-center gap-2">
      <li><a href="/admin" class="hover:text-accent">Admin</a></li>
      <li aria-hidden="true">/</li>
      <li><a href="/admin/devis" class="hover:text-accent">Devis B2B</a></li>
      <li aria-hidden="true">/</li>
      <li class="text-primary">{quote.company_name}</li>
    </ol>
  </nav>

  {
    updated && (
      <div class="mb-4 rounded-card border border-green-200 bg-green-50 p-3 text-sm text-green-800">
        ✓ Devis mis à jour.
      </div>
    )
  }
  {
    errParam && (
      <div class="mb-4 rounded-card border border-danger/30 bg-danger/5 p-3 text-sm text-danger">
        Erreur lors de la mise à jour.
      </div>
    )
  }

  <div class="grid gap-6 lg:grid-cols-[1fr_280px]">
    <article class="rounded-card border border-primary/10 bg-white p-6 shadow-card">
      <header class="border-b border-primary/10 pb-4">
        <h1 class="font-display text-xl font-semibold text-primary">{quote.company_name}</h1>
        <p class="mt-1 text-xs text-primary/60">
          Reçu le {dateFmt.format(new Date(quote.created_at))}
          {quote.source && ` · source : ${quote.source}`}
        </p>
      </header>

      <dl class="mt-4 space-y-3 text-sm">
        <div class="grid grid-cols-3 gap-2">
          <dt class="text-primary/60">Contact</dt>
          <dd class="col-span-2 text-primary">{quote.contact_name}</dd>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <dt class="text-primary/60">Email</dt>
          <dd class="col-span-2">
            <a href={`mailto:${quote.email}`} class="text-accent hover:text-accent-hover"
              >{quote.email}</a
            >
          </dd>
        </div>
        {
          quote.phone && (
            <div class="grid grid-cols-3 gap-2">
              <dt class="text-primary/60">Téléphone</dt>
              <dd class="col-span-2">
                <a
                  href={`tel:${quote.phone.replace(/\s/g, '')}`}
                  class="text-accent hover:text-accent-hover"
                >
                  {quote.phone}
                </a>
              </dd>
            </div>
          )
        }
        {
          quote.siret && (
            <div class="grid grid-cols-3 gap-2">
              <dt class="text-primary/60">SIRET</dt>
              <dd class="col-span-2 font-mono text-xs text-primary">{quote.siret}</dd>
            </div>
          )
        }
        {
          quote.attachment_url && (
            <div class="grid grid-cols-3 gap-2">
              <dt class="text-primary/60">Pièce jointe</dt>
              <dd class="col-span-2">
                <a
                  href={quote.attachment_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:text-accent-hover"
                >
                  Télécharger
                </a>
              </dd>
            </div>
          )
        }
      </dl>

      <div class="mt-6 border-t border-primary/10 pt-4">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-primary/60">Demande</h2>
        <p class="mt-2 whitespace-pre-wrap text-sm text-primary/90">{quote.message}</p>
      </div>
    </article>

    <aside class="space-y-4">
      <form
        method="POST"
        action="/api/admin/devis-status"
        class="rounded-card border border-primary/10 bg-white p-4 shadow-card"
      >
        <input type="hidden" name="id" value={quote.id} />
        <label for="status" class="text-xs font-semibold uppercase tracking-wider text-primary/60">
          Changer le statut
        </label>
        <select
          id="status"
          name="status"
          class="mt-2 h-10 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
        >
          {
            allowedStatuses.map((s) => (
              <option value={s} selected={s === quote.status}>
                {statusLabels[s]}
              </option>
            ))
          }
        </select>
        <button
          type="submit"
          class="mt-3 inline-flex h-10 w-full items-center justify-center rounded-btn bg-primary px-4 text-sm font-medium text-white hover:bg-primary/90"
        >
          Mettre à jour
        </button>
      </form>

      <div class="rounded-card border border-primary/10 bg-white p-4 text-xs text-primary/60">
        <p class="font-medium text-primary">Actions rapides</p>
        <ul class="mt-2 space-y-1">
          <li>
            <a
              href={`mailto:${quote.email}?subject=Devis%20${encodeURIComponent(quote.company_name)}&body=Bonjour%20${encodeURIComponent(quote.contact_name)}%2C%0A%0AMerci%20pour%20votre%20demande%20de%20devis...`}
              class="text-accent hover:text-accent-hover"
            >
              Répondre par email →
            </a>
          </li>
        </ul>
      </div>
    </aside>
  </div>
</AdminLayout>
