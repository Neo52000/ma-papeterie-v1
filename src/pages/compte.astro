---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AccountDashboard from '@/components/account/AccountDashboard';

export const prerender = true;
---

<BaseLayout
  title="Mon compte - Ma Papeterie"
  description="Espace client Ma Papeterie."
  canonical="https://ma-papeterie-v1.netlify.app/compte"
  noindex
>
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    <h1 class="font-display text-3xl font-semibold text-primary">Mon compte</h1>

    <div class="mt-8">
      <AccountDashboard client:only="react" />
    </div>
  </main>
</BaseLayout>
