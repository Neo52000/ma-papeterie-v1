---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ImageGallery from '@/components/product/ImageGallery';
import ProductCard from '@/components/product/ProductCard.astro';
import StockBadge from '@/components/product/StockBadge.astro';
import AddToCartButton from '@/components/product/AddToCartButton';
import WishlistButton from '@/components/product/WishlistButton';
import NotifyBackInStock from '@/components/product/NotifyBackInStock';
import RecentlyViewedTracker from '@/components/product/RecentlyViewedTracker';
import RecentlyViewedSection from '@/components/product/RecentlyViewedSection';
import SimilarProductsAI from '@/components/product/SimilarProductsAI';
import {
  fetchProductBySlug,
  fetchProductImages,
  fetchRelatedProducts,
  getStockState,
  productImage,
} from '@/lib/queries';
import { computeDisplayPrice, computeDisplayPrices, fetchPricingCoefficients } from '@/lib/pricing';
import { breadcrumbSchema, productSchema } from '@/lib/schema';
import { formatPrice } from '@/lib/utils';

export const prerender = false;

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/catalogue', 302);

const product = await fetchProductBySlug(slug);
if (!product) {
  // Smart redirect: feed the slug words back into search. The slug is
  // usually `cahier-spirale-a4-100p` — strip pagination/SKU-ish trailing
  // segments and decode any %XX. Cap at 60 chars to avoid URL bloat.
  const searchQuery = slug
    .replace(/-/g, ' ')
    .replace(/\b(a4|a3|a5|\d{1,3}p|\d{1,3}g|\d{1,3}mm|\d{1,3}cm)\b/gi, '')
    .replace(/\s+/g, ' ')
    .trim()
    .slice(0, 60);
  if (searchQuery.length >= 3) {
    return Astro.redirect(`/catalogue?q=${encodeURIComponent(searchQuery)}`, 301);
  }
  return Astro.rewrite('/404');
}

const [rawImages, related, coefs] = await Promise.all([
  fetchProductImages(product.id).catch(() => []),
  fetchRelatedProducts(product.id, product.category, 4).catch(() => []),
  fetchPricingCoefficients(),
]);

const galleryImages = (
  rawImages.length > 0 ? rawImages.map((img) => img.url_originale) : [productImage(product)]
).filter(Boolean);

const stock = getStockState(product);
const qty = Math.max(product.stock_quantity ?? 0, product.available_qty_total ?? 0);
const { ht, ttc } = computeDisplayPrice(product, coefs);
const relatedPrices = computeDisplayPrices(related, coefs);

// Ajustement #4 — anchor effect: show public_price_ttc (supplier-suggested retail
// price) struck through only when it's at least 10% above our sell price, i.e.
// our offer is materially cheaper. If public_price_ttc is missing or too close
// to our TTC, we don't render the strike-through.
const publicTTC =
  product.public_price_ttc != null && Number(product.public_price_ttc) > 0
    ? Number(product.public_price_ttc)
    : null;
const showAnchor = publicTTC !== null && publicTTC > ttc * 1.1;
const discountPct = showAnchor ? Math.round((1 - ttc / publicTTC) * 100) : 0;

const siteUrl = import.meta.env.PUBLIC_SITE_URL;
const canonical = `${siteUrl}/produit/${slug}`;
const description =
  (product.description ?? '').trim() ||
  `${product.name} — disponible en ligne chez Ma Papeterie, Chaumont (52).`;
const shortDesc =
  description.length > 155 ? description.slice(0, 152).trimEnd() + '…' : description;

const availabilityForSchema: 'in_stock' | 'out_of_stock' | 'low_stock' =
  stock === 'in_stock' ? 'in_stock' : stock === 'low_stock' ? 'low_stock' : 'out_of_stock';

const jsonLd = [
  breadcrumbSchema([
    { name: 'Accueil', url: siteUrl },
    { name: 'Catalogue', url: `${siteUrl}/catalogue` },
    {
      name: product.category,
      url: `${siteUrl}/catalogue?category=${encodeURIComponent(product.category)}`,
    },
    { name: product.name, url: canonical },
  ]),
  productSchema({
    name: product.name,
    description,
    sku: product.ean ?? product.id,
    brand: product.brand ?? undefined,
    image: galleryImages,
    priceTTC: ttc,
    availability: availabilityForSchema,
    url: canonical,
  }),
];
---

<BaseLayout
  title={product.name}
  description={shortDesc}
  canonical={canonical}
  ogType="product"
  ogImage={galleryImages[0]}
  jsonLd={jsonLd}
>
  <section class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
    <nav aria-label="Fil d'Ariane" class="mb-6 text-xs text-primary/60">
      <ol class="flex flex-wrap items-center gap-2">
        <li><a href="/" class="hover:text-accent">Accueil</a></li>
        <li aria-hidden="true">/</li>
        <li><a href="/catalogue" class="hover:text-accent">Catalogue</a></li>
        <li aria-hidden="true">/</li>
        <li>
          <a
            href={`/catalogue?category=${encodeURIComponent(product.category)}`}
            class="hover:text-accent"
          >
            {product.category}
          </a>
        </li>
        <li aria-hidden="true">/</li>
        <li class="truncate text-primary" aria-current="page">{product.name}</li>
      </ol>
    </nav>

    <div class="grid gap-10 lg:grid-cols-[minmax(0,1fr)_minmax(0,460px)]">
      <ImageGallery client:visible images={galleryImages} alt={product.name} />

      <div class="flex flex-col gap-6">
        <div>
          {product.brand && <span class="label-category">{product.brand}</span>}
          <h1 class="mt-2 font-display text-3xl font-semibold text-primary sm:text-4xl">
            {product.name}
          </h1>
          <dl class="mt-3 grid grid-cols-2 gap-2 text-xs text-primary/60">
            {
              product.ean && (
                <>
                  <dt class="font-medium text-primary/70">EAN</dt>
                  <dd>{product.ean}</dd>
                </>
              )
            }
            {
              product.manufacturer_code && (
                <>
                  <dt class="font-medium text-primary/70">Référence fab.</dt>
                  <dd>{product.manufacturer_code}</dd>
                </>
              )
            }
          </dl>
        </div>

        <div class="flex items-center gap-3">
          <StockBadge state={stock} quantity={qty} />
          {product.badge && <span class="badge-new">{product.badge.toUpperCase()}</span>}
        </div>

        <div class="flex flex-col gap-1">
          {
            showAnchor && publicTTC !== null && (
              <div class="flex items-baseline gap-2">
                <span class="text-sm text-primary/40 line-through">
                  {formatPrice(publicTTC, { mode: 'TTC', vatRate: 0 })} TTC
                </span>
                <span class="text-xs font-medium text-success">−{discountPct}%</span>
              </div>
            )
          }
          <div class="font-display text-3xl font-semibold text-primary">
            {formatPrice(ttc, { mode: 'HT', vatRate: 0 })}
            <span class="text-sm font-normal text-primary/60"> TTC</span>
          </div>
          <div class="text-sm text-primary/60">
            {formatPrice(ht, { mode: 'HT', vatRate: 0 })} HT
          </div>
        </div>

        {
          product.shopify_variant_id ? (
            <AddToCartButton
              client:load
              variantId={product.shopify_variant_id}
              productSupabaseId={product.id}
              productName={product.name}
              productSlug={slug}
              imageUrl={galleryImages[0] ?? null}
              brand={product.brand}
              unitPriceTtc={ttc}
              unitPriceHt={ht}
              compareAtTtc={showAnchor ? publicTTC : null}
              disabled={stock === 'out_of_stock'}
              maxQuantity={qty > 0 ? qty : undefined}
            />
          ) : ttc < 50 ? (
            <div class="rounded-card bg-bg-soft p-4 text-center">
              <p class="text-sm font-medium text-primary">Achat en ligne disponible bientôt</p>
              <p class="mt-1 text-xs text-primary/60">
                Module e-commerce en cours de finalisation (Phase 3 — mai 2026).
                <br />
                En attendant,{' '}
                <a href="/contact" class="font-medium text-accent hover:text-accent-hover">
                  contactez-nous
                </a>
                .
              </p>
            </div>
          ) : (
            <div class="flex flex-col gap-2">
              <a
                href={`/devis?produit=${encodeURIComponent(product.id)}`}
                class="inline-flex h-12 w-full items-center justify-center rounded-btn bg-accent px-6 text-sm font-medium text-white hover:bg-accent-hover"
              >
                Demander un devis personnalisé
              </a>
              <p class="text-center text-xs text-primary/50">
                Devis sous 24h · Prix dégressifs sur volume
              </p>
            </div>
          )
        }

        {
          stock === 'out_of_stock' && product.shopify_variant_id && (
            <div class="mt-3">
              <NotifyBackInStock client:idle productId={product.id} />
            </div>
          )
        }

        <div class="mt-3">
          <WishlistButton
            client:idle
            productId={product.id}
            productName={product.name}
            variant="full"
          />
        </div>

        {
          product.description && (
            <div>
              <h2 class="label-category">Description</h2>
              <p class="mt-2 whitespace-pre-line text-sm leading-relaxed text-primary/80">
                {product.description}
              </p>
            </div>
          )
        }

        <details class="rounded-card border border-primary/10 bg-white">
          <summary
            class="flex cursor-pointer items-center justify-between px-5 py-4 text-sm font-medium text-primary"
          >
            Livraison & retour
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg
            >
          </summary>
          <div class="space-y-2 border-t border-primary/10 px-5 py-4 text-sm text-primary/70">
            <p>• Retrait gratuit en boutique à Chaumont (52) sous 24h ouvrées.</p>
            <p>• Livraison Colissimo en France métropolitaine (2–4 jours ouvrés).</p>
            <p>• Retour sous 14 jours, produit non ouvert et dans son emballage d'origine.</p>
          </div>
        </details>
      </div>
    </div>

    <aside class="mt-16">
      <h2 class="font-display text-2xl font-semibold text-primary">Produits similaires</h2>
      <p class="mt-1 text-sm text-primary/60">
        Sélection IA basée sur les caractéristiques du produit.
      </p>
      <div class="mt-6">
        <SimilarProductsAI client:idle productId={product.id} />
      </div>
    </aside>

    {
      related.length > 0 && (
        <aside class="mt-16">
          <h2 class="font-display text-2xl font-semibold text-primary">Dans la même catégorie</h2>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {related.map((item) => (
              <ProductCard product={item} prices={relatedPrices.get(item.id)} />
            ))}
          </div>
        </aside>
      )
    }

    <RecentlyViewedTracker client:load productId={product.id} />
    <RecentlyViewedSection client:idle currentProductId={product.id} />
  </section>
</BaseLayout>
