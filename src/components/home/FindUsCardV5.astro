---
// V5 parity (Phase 5.1) — bloc "Nous trouver" centré, pied de section
// SEO. Donne l'adresse boutique, téléphone, email et horaires.
//
// Sert aussi de Schema.org LocalBusiness micro-data côté HTML brut
// (en plus du JSON-LD organisationSchema dans BaseLayout) — chaque
// signal compte pour le SEO local Chaumont.
---

<section class="border-t border-primary/10 bg-bg-soft py-10" aria-label="Nous trouver">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6">
    <h2 class="font-display text-xl font-semibold text-primary">Nous trouver</h2>
    <div class="mt-4 space-y-2 text-sm text-primary/80">
      <p class="font-semibold text-primary">Papeterie Reine &amp; Fils</p>
      <p>10 rue Toupot de Beveaux, 52000 Chaumont</p>
      <p>
        Tél :
        <a href="tel:+33310960224" class="font-medium text-primary hover:text-accent-dark">
          03 10 96 02 24
        </a>
      </p>
      <p>
        Email :
        <a
          href="mailto:contact@ma-papeterie.fr"
          class="font-medium text-primary hover:text-accent-dark"
        >
          contact@ma-papeterie.fr
        </a>
      </p>
      <p>Horaires : Lun–Ven 9h–19h, Sam 9h–18h</p>
    </div>
  </div>
</section>
