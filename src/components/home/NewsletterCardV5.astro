---
// V5 parity (Phase 5.1) — bloc newsletter centré, fond bleu primary
// avec overlay légèrement glow.
//
// Layout V5 : carte radius card, bleu marine, gauche = titre + pitch +
// disclaimer, droite = input email + bouton CTA orange.
//
// Réutilise l'island NewsletterSignup existante pour la logique
// (Brevo POST, double opt-in, anti-bot honeypot).

import NewsletterSignup from '@/components/layout/NewsletterSignup';

interface Props {
  /** "footer" envoie à la liste générale, "b2b" tag les pros (V5 segmente côté liste). */
  source?: 'footer' | 'b2b';
}

const { source = 'footer' } = Astro.props;
---

<section class="bg-bg-soft py-10 sm:py-14" aria-label="Inscription à la newsletter">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div
      class="relative overflow-hidden rounded-card bg-gradient-to-br from-primary via-primary to-primary-dark p-8 text-white shadow-card sm:p-10"
    >
      <span
        aria-hidden="true"
        class="pointer-events-none absolute -right-16 -top-16 h-48 w-48 rounded-full bg-accent/15 blur-3xl"
      ></span>
      <div class="relative grid gap-8 lg:grid-cols-[1.4fr_1fr] lg:items-center">
        <div>
          <span
            class="inline-flex items-center gap-2 rounded-badge bg-white/10 px-3 py-1 text-xs font-semibold uppercase tracking-label text-white/90"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            Newsletter
          </span>
          <h2 class="mt-3 font-display text-2xl font-semibold sm:text-3xl">
            Les offres pro, directement dans votre boîte mail
          </h2>
          <p class="mt-3 max-w-md text-sm text-white/80 sm:text-base">
            Bons plans fournitures, nouveautés et guides pratiques — 2 emails par mois, zéro spam,
            désinscription en 1 clic.
          </p>
        </div>
        <div>
          <NewsletterSignup source={source} client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
