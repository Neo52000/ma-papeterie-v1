---
// V5 parity (Phase 5.1) — section "Conseils & guides" : 3 cartes blog
// avec aplat coloré (V5 utilise des couleurs douces typées par catégorie).
//
// Le blog est shipped (PR #179). Les 3 cartes ci-dessous pointent vers
// /blog en attendant que des articles soient publiés — l'idéal sera de
// remplacer les hrefs par /blog/<slug> et les titres par les titres réels
// des derniers posts (à automatiser via fetchPublishedPosts() le jour où
// 3+ articles sont en ligne). Pour l'instant elles servent de teaser
// éditorial qui amène vers la landing /blog (avec son propre empty state
// si rien n'est encore publié).

import { fetchPublishedPosts } from '@/lib/blog';

interface Card {
  category: string;
  title: string;
  href: string;
  bgClass: string;
  illustration?: string;
}

const FALLBACK: Card[] = [
  {
    category: 'Organisation',
    title: 'Comment bien organiser son poste de travail ?',
    href: '/blog',
    bgClass: 'bg-blue-50',
    illustration: '💼',
  },
  {
    category: 'Rentrée',
    title: 'Les indispensables pour une rentrée réussie',
    href: '/blog',
    bgClass: 'bg-amber-50',
    illustration: '🎒',
  },
  {
    category: 'Ergonomie',
    title: 'Le guide complet du mobilier ergonomique',
    href: '/blog',
    bgClass: 'bg-yellow-50',
    illustration: '🪑',
  },
];

const BG_ROTATION = ['bg-blue-50', 'bg-amber-50', 'bg-yellow-50'];
const EMOJI_ROTATION = ['💼', '🎒', '🪑'];

// Try to surface the 3 most recent published posts. If the blog table is
// empty (or the migration hasn't been applied yet on this env), fall back
// to the static teaser cards above so the home stays well-furnished.
let cards: Card[] = FALLBACK;
try {
  const posts = await fetchPublishedPosts(3);
  if (posts.length > 0) {
    cards = posts.map((p, i) => ({
      category: 'Conseils',
      title: p.title,
      href: `/blog/${p.slug}`,
      bgClass: BG_ROTATION[i % BG_ROTATION.length],
      illustration: EMOJI_ROTATION[i % EMOJI_ROTATION.length],
    }));
  }
} catch {
  // Silent fallback — the section is editorial and shouldn't crash the home.
}
---

<section class="bg-bg-soft py-14" aria-label="Conseils et guides">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <div>
        <span class="label-category">Ressources</span>
        <h2 class="mt-2 font-display text-3xl font-semibold text-primary sm:text-4xl">
          Conseils &amp; guides
        </h2>
      </div>
      <a
        href="/blog"
        class="hidden items-center gap-1 text-sm font-medium text-primary hover:text-accent-dark sm:inline-flex"
      >
        Voir tous les articles <span aria-hidden="true">→</span>
      </a>
    </div>

    <ul class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        cards.map((card) => (
          <li>
            <a
              href={card.href}
              class="group flex h-full flex-col overflow-hidden rounded-card border border-primary/10 bg-white shadow-card transition-all hover:-translate-y-1 hover:shadow-card-hover"
            >
              <div
                class:list={['flex h-44 items-center justify-center text-5xl', card.bgClass]}
                aria-hidden="true"
              >
                {card.illustration}
              </div>
              <div class="flex flex-1 flex-col p-5">
                <span class="label-category">{card.category}</span>
                <h3 class="mt-2 flex-1 font-display text-base font-semibold text-primary">
                  {card.title}
                </h3>
                <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent-dark group-hover:underline">
                  Lire l’article <span aria-hidden="true">→</span>
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
