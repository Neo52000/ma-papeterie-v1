---
// V5 parity (Phase 5.1) — section "Explorez nos univers" : grille
// d'images de catégories avec label dessous. 4 colonnes desktop, 2
// colonnes mobile.
//
// Chaque tile = image carrée + label centré sous l'image. Les images
// sont passées en props (URLs Comlandi/Shopify CDN ou Netlify Image
// Optimization). Si une image est manquante, un placeholder coloré
// s'affiche.

interface Tile {
  label: string;
  href: string;
  imageSrc?: string;
  /** Couleur Tailwind du placeholder si pas d'image (ex: 'bg-blue-50') */
  placeholderBg?: string;
}

interface Props {
  tiles?: Tile[];
}

// Hrefs target /catalogue/<slug> (the dedicated route that resolves the
// slug to the real DB category name via fetchCategoryBySlug). The
// previous `?category=<slug>` querystring form did `eq('category', slug)`
// against the products table — but slugs ('mobilier') don't match the
// category names ('MOBILIER') so every tile rendered an empty page and
// 301'd back to /catalogue. Confirmed against DB: slugs below all map
// to populated categories (10–1187 visible products).
const {
  tiles = [
    {
      label: 'Petite fourniture',
      href: '/catalogue/petit-materiel-bureau-et-ecole',
      placeholderBg: 'bg-orange-50',
    },
    {
      label: 'Écriture & correction',
      href: '/catalogue/ecrire-et-corriger',
      placeholderBg: 'bg-amber-50',
    },
    {
      label: 'Classement',
      href: '/catalogue/classement',
      placeholderBg: 'bg-emerald-50',
    },
    {
      label: 'Papiers',
      href: '/catalogue/papiers',
      placeholderBg: 'bg-blue-50',
    },
    {
      label: 'Encre & toners',
      href: '/catalogue/consommables-informatiques',
      placeholderBg: 'bg-slate-100',
    },
    {
      label: 'Mobilier',
      href: '/catalogue/mobilier',
      placeholderBg: 'bg-stone-100',
    },
    {
      label: 'Cahiers scolaires',
      href: '/catalogue/cahiers-scolaires',
      placeholderBg: 'bg-sky-50',
    },
    {
      label: 'Emballage',
      href: '/catalogue/emballage',
      placeholderBg: 'bg-yellow-50',
    },
  ],
} = Astro.props as Props;
---

<section class="bg-bg-soft py-14" aria-label="Explorez nos univers">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex items-end justify-between gap-4">
      <h2 class="font-display text-3xl font-semibold text-primary sm:text-4xl">
        Explorez nos univers
      </h2>
      <a
        href="/catalogue"
        class="hidden items-center gap-1 text-sm font-medium text-primary hover:text-accent-dark sm:inline-flex"
      >
        Voir tout le catalogue <span aria-hidden="true">→</span>
      </a>
    </div>

    <ul class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
      {
        tiles.map((tile) => (
          <li>
            <a
              href={tile.href}
              class="group block overflow-hidden rounded-card border border-primary/5 bg-white shadow-card transition-all hover:-translate-y-0.5 hover:shadow-card-hover"
            >
              <div
                class:list={[
                  'aspect-square w-full overflow-hidden',
                  tile.imageSrc ? '' : (tile.placeholderBg ?? 'bg-bg-soft'),
                ]}
              >
                {tile.imageSrc ? (
                  <img
                    src={tile.imageSrc}
                    alt={tile.label}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                ) : (
                  <span
                    class="flex h-full w-full items-center justify-center text-primary/30"
                    aria-hidden="true"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="48"
                      height="48"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect width="18" height="18" x="3" y="3" rx="2" />
                      <circle cx="9" cy="9" r="2" />
                      <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                    </svg>
                  </span>
                )}
              </div>
              <p class="px-3 py-3 text-center text-sm font-medium text-primary">{tile.label}</p>
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</section>
