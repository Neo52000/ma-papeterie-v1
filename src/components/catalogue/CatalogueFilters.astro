---
import type { SortKey } from '@/lib/queries';

export interface Props {
  categories: string[];
  brands: string[];
  selected: {
    category?: string | string[];
    brand?: string | string[];
    priceMin?: number;
    priceMax?: number;
    inStockOnly?: boolean;
    search?: string;
    sort?: SortKey;
  };
}

const { categories, brands, selected } = Astro.props;

const toArray = (v: string | string[] | undefined): string[] =>
  v == null ? [] : Array.isArray(v) ? v : [v];

const selectedCategories = new Set(toArray(selected.category));
const selectedBrands = new Set(toArray(selected.brand));

// Mobile multi-select fix: <select multiple size=6> renders as a single-pick
// roulette on iOS / Android, so the "Ctrl+clic = multi" hint was misleading
// and the filter was effectively broken on mobile (>50% of traffic). Replaced
// with a scrollable checkbox group: a) works identically on every input
// modality, b) keeps a 6-line viewport so the sidebar doesn't grow unbounded.
---

<form
  method="get"
  action="/catalogue"
  class="flex flex-col gap-4 rounded-card border border-primary/10 bg-white p-4"
  aria-label="Filtres catalogue"
>
  <div>
    <label for="f-search" class="label-category">Recherche</label>
    <input
      id="f-search"
      type="search"
      name="q"
      value={selected.search ?? ''}
      placeholder="Cartouche, stylo, agenda…"
      class="mt-2 h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
    />
  </div>

  <fieldset>
    <legend class="label-category">
      Catégories
      <span class="ml-1 text-[10px] font-normal text-primary/50">
        ({selectedCategories.size} sélectionnée{selectedCategories.size > 1 ? 's' : ''})
      </span>
    </legend>
    <div
      class="mt-2 max-h-44 space-y-1 overflow-y-auto rounded-btn border border-primary/15 bg-white p-2"
      role="group"
      aria-label="Filtrer par catégorie"
    >
      {
        categories.map((cat) => (
          <label class="flex cursor-pointer items-center gap-2 rounded px-2 py-1.5 text-sm text-primary hover:bg-bg-soft">
            <input
              type="checkbox"
              name="category"
              value={cat}
              checked={selectedCategories.has(cat)}
              class="h-4 w-4 shrink-0 rounded border-primary/20 text-accent focus:ring-accent"
            />
            <span class="line-clamp-1">{cat}</span>
          </label>
        ))
      }
    </div>
  </fieldset>

  <fieldset>
    <legend class="label-category">
      Marques
      <span class="ml-1 text-[10px] font-normal text-primary/50">
        ({selectedBrands.size} sélectionnée{selectedBrands.size > 1 ? 's' : ''})
      </span>
    </legend>
    <div
      class="mt-2 max-h-44 space-y-1 overflow-y-auto rounded-btn border border-primary/15 bg-white p-2"
      role="group"
      aria-label="Filtrer par marque"
    >
      {
        brands.map((brand) => (
          <label class="flex cursor-pointer items-center gap-2 rounded px-2 py-1.5 text-sm text-primary hover:bg-bg-soft">
            <input
              type="checkbox"
              name="brand"
              value={brand}
              checked={selectedBrands.has(brand)}
              class="h-4 w-4 shrink-0 rounded border-primary/20 text-accent focus:ring-accent"
            />
            <span class="line-clamp-1">{brand}</span>
          </label>
        ))
      }
    </div>
  </fieldset>

  <div>
    <span class="label-category">Prix TTC (€)</span>
    <div class="mt-2 grid grid-cols-2 gap-2">
      <div>
        <label for="f-price-min" class="sr-only">Prix minimum</label>
        <input
          id="f-price-min"
          type="number"
          name="priceMin"
          min="0"
          step="1"
          value={selected.priceMin ?? ''}
          placeholder="Min"
          class="h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
        />
      </div>
      <div>
        <label for="f-price-max" class="sr-only">Prix maximum</label>
        <input
          id="f-price-max"
          type="number"
          name="priceMax"
          min="0"
          step="1"
          value={selected.priceMax ?? ''}
          placeholder="Max"
          class="h-11 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
        />
      </div>
    </div>
  </div>

  <label class="flex items-center gap-2 text-sm text-primary">
    <input
      type="checkbox"
      name="inStock"
      value="1"
      checked={selected.inStockOnly}
      class="h-4 w-4 rounded border-primary/20 text-accent focus:ring-accent"
    />
    En stock uniquement
  </label>

  <input type="hidden" name="sort" value={selected.sort ?? 'pertinence'} />

  <div class="flex items-center justify-between gap-2 pt-2">
    <a href="/catalogue" class="text-xs text-primary/60 hover:text-accent">Réinitialiser</a>
    <button
      type="submit"
      class="inline-flex h-11 items-center rounded-btn bg-primary px-4 text-sm font-medium text-white hover:bg-primary/90"
    >
      Appliquer
    </button>
  </div>
</form>
