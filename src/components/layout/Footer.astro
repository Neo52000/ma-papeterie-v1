---
import { localBusinessSchema } from '@/lib/schema';

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t border-primary/10 bg-bg-soft">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <h3 class="font-display text-sm font-semibold text-primary">Boutique</h3>
        <address class="mt-4 space-y-2 text-sm not-italic text-primary/70">
          <div class="flex items-start gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="mt-0.5 flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>10 rue Toupot de Béveaux<br />52000 Chaumont</span>
          </div>
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"
              ></path>
            </svg>
            <a href="tel:+33310960224" class="hover:text-accent">03 10 96 02 24</a>
          </div>
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <rect width="20" height="16" x="2" y="4" rx="2"></rect>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
            </svg>
            <a href="mailto:contact@ma-papeterie.fr" class="hover:text-accent"
              >contact@ma-papeterie.fr</a
            >
          </div>
          <p class="pt-2 text-xs text-primary/50">Lundi–Samedi · 9h–18h</p>
        </address>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold text-primary">Aide</h3>
        <ul class="mt-4 space-y-2 text-sm text-primary/70">
          <li><a href="/contact" class="hover:text-accent">Contact</a></li>
          <li><a href="/livraison-retour" class="hover:text-accent">Livraison &amp; retour</a></li>
          <li><a href="/devis" class="hover:text-accent">Demande de devis B2B</a></li>
          <li><a href="/liste-scolaire" class="hover:text-accent">Liste scolaire</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold text-primary">Légal</h3>
        <ul class="mt-4 space-y-2 text-sm text-primary/70">
          <li><a href="/mentions-legales" class="hover:text-accent">Mentions légales</a></li>
          <li><a href="/cgv" class="hover:text-accent">CGV</a></li>
          <li><a href="/confidentialite" class="hover:text-accent">Confidentialité</a></li>
          <li><a href="/cookies" class="hover:text-accent">Cookies</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-display text-sm font-semibold text-primary">Confiance</h3>
        <ul class="mt-4 grid grid-cols-1 gap-2 text-xs text-primary/70 sm:grid-cols-2">
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"></path>
            </svg>
            Paiement sécurisé
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"></path>
              <path d="M15 18H9"></path>
              <path
                d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"
              ></path>
              <circle cx="17" cy="18" r="2"></circle>
              <circle cx="7" cy="18" r="2"></circle>
            </svg>
            Livraison rapide
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <rect width="20" height="14" x="2" y="5" rx="2"></rect>
              <line x1="2" x2="22" y1="10" y2="10"></line>
            </svg>
            CB, virement
          </li>
          <li class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="flex-shrink-0 text-accent"
              aria-hidden="true"
            >
              <path d="M9 18V5l12-2v13"></path>
              <circle cx="6" cy="18" r="3"></circle>
              <circle cx="18" cy="16" r="3"></circle>
            </svg>
            Retrait boutique
          </li>
        </ul>
        <div class="mt-6">
          <p class="text-xs font-medium text-primary">Suivez-nous</p>
          <div class="mt-2 flex gap-2">
            <a
              href="https://www.facebook.com/papeteriereineetchaumont"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Facebook Ma Papeterie"
              class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-primary/15 text-primary transition-colors hover:border-accent hover:text-accent"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12Z"
                ></path>
              </svg>
            </a>
            <a
              href="https://www.instagram.com/mapapeterie_chaumont"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Instagram Ma Papeterie"
              class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-primary/15 text-primary transition-colors hover:border-accent hover:text-accent"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-primary/10 pt-6 text-xs text-primary/60 md:flex-row"
    >
      <p>&copy; {year} Ma Papeterie — Reine &amp; Fils. Tous droits réservés.</p>
      <p>SIRET&nbsp;: 100 208 883 00015 — TVA&nbsp;: FR90100208883</p>
    </div>
  </div>

  <script type="application/ld+json" set:html={localBusinessSchema()} />
</footer>
