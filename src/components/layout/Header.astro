---
// Phase 1 header — search & cart icons are stubs. Full interactivity (mobile menu
// React island, live cart count, account dropdown) ships in Phase 2.
---

<header class="sticky top-0 z-40 border-b border-primary/10 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="Ma Papeterie — Accueil">
      <span class="font-display text-lg font-semibold text-primary">Ma Papeterie</span>
      <span class="label-category hidden sm:inline">Reine &amp; Fils</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden items-center gap-6 md:flex">
      <a href="/catalogue" class="text-sm font-medium text-primary hover:text-accent transition-colors">
        Catalogue
      </a>
      <a href="/liste-scolaire" class="text-sm font-medium text-primary hover:text-accent transition-colors">
        Liste scolaire
      </a>
      <a href="/devis" class="text-sm font-medium text-primary hover:text-accent transition-colors">
        Devis B2B
      </a>
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        aria-label="Rechercher"
        class="inline-flex h-10 w-10 items-center justify-center rounded-btn text-primary hover:bg-bg-soft"
        disabled
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </button>
      <a href="/compte" aria-label="Mon compte" class="inline-flex h-10 w-10 items-center justify-center rounded-btn text-primary hover:bg-bg-soft">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </a>
      <a href="/panier" aria-label="Panier" class="inline-flex h-10 w-10 items-center justify-center rounded-btn text-primary hover:bg-bg-soft">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
      </a>

      <details class="relative md:hidden">
        <summary aria-label="Menu mobile" class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-btn text-primary hover:bg-bg-soft">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="12" y2="12" />
            <line x1="4" x2="20" y1="6" y2="6" />
            <line x1="4" x2="20" y1="18" y2="18" />
          </svg>
        </summary>
        <nav aria-label="Navigation mobile" class="absolute right-0 mt-2 w-56 rounded-card bg-white p-2 shadow-card">
          <a href="/catalogue" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Catalogue</a>
          <a href="/liste-scolaire" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Liste scolaire</a>
          <a href="/devis" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Devis B2B</a>
        </nav>
      </details>
    </div>
  </div>
</header>
