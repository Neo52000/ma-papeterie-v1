---
import CartTrigger from '@/components/cart/CartTrigger';
import CartDrawer from '@/components/cart/CartDrawer';
import AccountTrigger from '@/components/layout/AccountTrigger';
import HeaderSearchAutocomplete from '@/components/layout/HeaderSearchAutocomplete';
import MobileMenu from '@/components/layout/MobileMenu';
import Toaster from '@/components/ui/Toaster';
---

<Toaster client:idle />

<header class="sticky top-0 z-40 border-b border-primary/10 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="Ma Papeterie — Accueil">
      <span class="font-display text-lg font-semibold text-primary">Ma Papeterie</span>
      <span class="label-category hidden sm:inline">Reine &amp; Fils</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden items-center gap-6 md:flex">
      <a
        href="/catalogue"
        class="text-sm font-medium text-primary transition-colors hover:text-accent"
      >
        Catalogue
      </a>
      <a
        href="/liste-scolaire"
        class="text-sm font-medium text-primary transition-colors hover:text-accent"
      >
        Liste scolaire
      </a>
      <a href="/devis" class="text-sm font-medium text-primary transition-colors hover:text-accent">
        Devis B2B
      </a>
    </nav>

    <div class="ml-auto hidden max-w-sm flex-1 items-center md:flex">
      <HeaderSearchAutocomplete client:idle />
    </div>

    <div class="flex items-center gap-2 md:ml-2">
      <AccountTrigger client:idle />
      <CartTrigger client:idle />
      <CartDrawer client:idle />

      <MobileMenu client:idle />
    </div>
  </div>
</header>
