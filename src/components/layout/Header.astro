---
import CartCount from '@/components/layout/CartCount';
---

<header class="sticky top-0 z-40 border-b border-primary/10 bg-white/95 backdrop-blur">
  <div class="mx-auto flex h-16 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center gap-2" aria-label="Ma Papeterie — Accueil">
      <span class="font-display text-lg font-semibold text-primary">Ma Papeterie</span>
      <span class="label-category hidden sm:inline">Reine &amp; Fils</span>
    </a>

    <nav aria-label="Navigation principale" class="hidden items-center gap-6 md:flex">
      <a href="/catalogue" class="text-sm font-medium text-primary transition-colors hover:text-accent">
        Catalogue
      </a>
      <a href="/liste-scolaire" class="text-sm font-medium text-primary transition-colors hover:text-accent">
        Liste scolaire
      </a>
      <a href="/devis" class="text-sm font-medium text-primary transition-colors hover:text-accent">
        Devis B2B
      </a>
    </nav>

    <form
      method="get"
      action="/catalogue"
      class="ml-auto hidden flex-1 max-w-sm items-center md:flex"
      role="search"
    >
      <label for="header-search" class="sr-only">Rechercher dans le catalogue</label>
      <div class="relative w-full">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="pointer-events-none absolute left-3 top-1/2 -translate-y-1/2 text-primary/50"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        <input
          id="header-search"
          type="search"
          name="q"
          placeholder="Rechercher un produit, une marque, un EAN…"
          class="h-10 w-full rounded-btn border border-primary/15 bg-white pl-10 pr-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
        />
      </div>
    </form>

    <div class="flex items-center gap-2 md:ml-2">
      <a
        href="/compte"
        aria-label="Mon compte"
        class="inline-flex h-10 w-10 items-center justify-center rounded-btn text-primary hover:bg-bg-soft"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </a>
      <a
        href="/panier"
        aria-label="Panier"
        class="relative inline-flex h-10 w-10 items-center justify-center rounded-btn text-primary hover:bg-bg-soft"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z" />
          <path d="M3 6h18" />
          <path d="M16 10a4 4 0 0 1-8 0" />
        </svg>
        <CartCount client:load />
      </a>

      <details class="relative md:hidden">
        <summary
          aria-label="Menu mobile"
          class="inline-flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-btn text-primary hover:bg-bg-soft"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="12" y2="12" />
            <line x1="4" x2="20" y1="6" y2="6" />
            <line x1="4" x2="20" y1="18" y2="18" />
          </svg>
        </summary>
        <nav aria-label="Navigation mobile" class="absolute right-0 mt-2 w-64 rounded-card bg-white p-2 shadow-card">
          <form method="get" action="/catalogue" class="p-2" role="search">
            <label for="header-search-mobile" class="sr-only">Rechercher</label>
            <input
              id="header-search-mobile"
              type="search"
              name="q"
              placeholder="Rechercher…"
              class="h-10 w-full rounded-btn border border-primary/15 bg-white px-3 text-sm text-primary focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/30"
            />
          </form>
          <a href="/catalogue" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Catalogue</a>
          <a href="/liste-scolaire" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Liste scolaire</a>
          <a href="/devis" class="block rounded-btn px-3 py-2 text-sm text-primary hover:bg-bg-soft">Devis B2B</a>
        </nav>
      </details>
    </div>
  </div>
</header>
