---
import CartTrigger from '@/components/cart/CartTrigger';
import CartDrawer from '@/components/cart/CartDrawer';
import AccountTrigger from '@/components/layout/AccountTrigger';
import HeaderSearchAutocomplete from '@/components/layout/HeaderSearchAutocomplete';
import MobileMenu from '@/components/layout/MobileMenu';
import PriceModeToggle from '@/components/layout/PriceModeToggle';
import WishlistTrigger from '@/components/layout/WishlistTrigger';
import Toaster from '@/components/ui/Toaster';

// Active nav match: pathname startsWith handles /catalogue, /catalogue/<cat>,
// /liste-scolaire, /liste-scolaire/, etc. Root path returned a false-positive
// for every link, so we test exact equality for `/` and prefix for the rest.
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string): boolean => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};

// Sub-nav (V5 parity, row 2). Limited to routes that actually exist in
// V1; Catalogues / Blog / Services / Professionnels dropdowns from V5
// stay TODO until the corresponding routes ship.
//
// "Promotions" intentionally absent: the products table has no
// compare_at_ttc column and no `is_on_promo` flag yet. Re-add when the
// promotions module lands (BACKLOG-V2 §V2.3).
const subNavLinks = [
  { href: '/catalogue', label: 'Catégories', badge: true },
  { href: '/liste-scolaire', label: 'Listes scolaires' },
  { href: '/contact', label: 'Contact' },
  { href: '/devis', label: 'Professionnels' },
];
---

<Toaster client:idle />

<header class="sticky top-0 z-40 border-b border-primary/10 bg-white/95 backdrop-blur">
  <!-- Row 1 — logo + search + actions -->
  <div class="mx-auto flex h-20 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center" aria-label="Ma Papeterie — Accueil">
      <picture>
        <source
          type="image/avif"
          srcset="/.netlify/images?url=%2Flogo-ma-papeterie.png&w=240&fm=avif&q=80 1x, /.netlify/images?url=%2Flogo-ma-papeterie.png&w=480&fm=avif&q=80 2x"
        />
        <source
          type="image/webp"
          srcset="/.netlify/images?url=%2Flogo-ma-papeterie.png&w=240&fm=webp&q=80 1x, /.netlify/images?url=%2Flogo-ma-papeterie.png&w=480&fm=webp&q=80 2x"
        />
        <img
          src="/.netlify/images?url=%2Flogo-ma-papeterie.png&w=240&q=80"
          alt="Ma Papeterie — Reine & Fils"
          width="240"
          height="49"
          class="h-11 w-auto sm:h-12"
          fetchpriority="high"
        />
      </picture>
    </a>

    <div class="hidden flex-1 md:block">
      <HeaderSearchAutocomplete client:idle />
    </div>

    <div class="ml-auto flex items-center gap-1 md:ml-2 md:gap-2">
      <a
        href="/connexion"
        class="hidden h-10 items-center rounded-btn bg-primary px-4 text-sm font-medium text-white transition-colors hover:bg-primary-light md:inline-flex"
      >
        Connexion
      </a>
      <AccountTrigger client:idle />
      <WishlistTrigger client:idle />
      <CartTrigger client:idle />
      <CartDrawer client:idle />
      <MobileMenu client:idle />
    </div>
  </div>

  <!-- Row 2 — sub-nav (V5 parity) -->
  <nav aria-label="Navigation principale" class="hidden border-t border-primary/5 md:block">
    <ul
      class="mx-auto flex max-w-7xl items-center gap-1 px-4 sm:px-6 lg:px-8 [&>li:last-child]:ml-auto"
    >
      {
        subNavLinks.map((link) => {
          const active = isActive(link.href.split('?')[0] ?? link.href);
          if (link.badge) {
            return (
              <li>
                <a
                  href={link.href}
                  aria-current={active ? 'page' : undefined}
                  class:list={[
                    'inline-flex h-11 items-center gap-2 rounded-badge px-3 text-sm font-semibold transition-colors',
                    active
                      ? 'bg-primary text-white'
                      : 'bg-primary text-white hover:bg-primary-light',
                  ]}
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect width="7" height="7" x="3" y="3" rx="1" />
                    <rect width="7" height="7" x="14" y="3" rx="1" />
                    <rect width="7" height="7" x="3" y="14" rx="1" />
                    <rect width="7" height="7" x="14" y="14" rx="1" />
                  </svg>
                  {link.label}
                </a>
              </li>
            );
          }
          return (
            <li>
              <a
                href={link.href}
                aria-current={active ? 'page' : undefined}
                class:list={[
                  'inline-flex h-11 items-center px-3 text-sm font-medium transition-colors',
                  active
                    ? 'border-b-2 border-accent text-primary'
                    : 'text-primary/80 hover:text-primary',
                ]}
              >
                {link.label}
              </a>
            </li>
          );
        })
      }
      <!-- Right-aligned utilities (HT/TTC toggle V5 parity). The
           `[&>li:last-child]:ml-auto` on the parent ul pushes whatever
           sits last in the row over to the far right. -->
      <li class="py-2">
        <PriceModeToggle client:idle />
      </li>
    </ul>
  </nav>

  <!-- Mobile-only search (row 1 hides search ≤ md) -->
  <div class="border-t border-primary/5 px-4 py-3 sm:px-6 md:hidden">
    <HeaderSearchAutocomplete client:idle />
  </div>
</header>
