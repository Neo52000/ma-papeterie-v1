---
import PriceDisplay from '@/components/product/PriceDisplay.astro';
import StockBadge from '@/components/product/StockBadge.astro';
import CdnImage from '@/components/ui/CdnImage.astro';
import { getDisplayPrices, getStockState, productHref, productImage } from '@/lib/queries';
import type { DisplayPrice } from '@/lib/pricing';
import type { Product } from '@/types/database';

export interface Props {
  product: Product;
  // Pre-computed price (pages that load the coefficient map should compute
  // once and pass through). When absent, fall back to the single-shot helper
  // with an empty coef map — the fallback branch of `computeDisplayPrice`.
  prices?: DisplayPrice;
}

const { product, prices } = Astro.props;
const href = productHref(product);
const image = productImage(product);
const stock = getStockState(product);
const { ht, ttc } = prices ?? getDisplayPrices(product);
const qty = product.stock_quantity ?? product.available_qty_total ?? 0;
---

<a
  href={href}
  class={`card-product group flex h-full flex-col ${stock === 'out_of_stock' ? 'opacity-60' : ''}`}
  aria-label={`Voir la fiche ${product.name}`}
>
  <div class="relative aspect-square w-full overflow-hidden bg-bg-soft">
    <CdnImage
      src={image}
      alt={product.name}
      width={300}
      height={300}
      loading="lazy"
      class="h-full w-full object-contain transition-transform duration-200 group-hover:scale-[1.03]"
    />
    {
      product.badge && (
        <span class="badge-new absolute left-3 top-3">{product.badge.toUpperCase()}</span>
      )
    }
  </div>

  <div class="flex flex-1 flex-col gap-2 p-4">
    {product.brand && <span class="label-category">{product.brand}</span>}
    <h3 class="line-clamp-2 text-sm font-semibold text-primary">{product.name}</h3>
    <div class="mt-auto flex items-end justify-between gap-2 pt-2">
      <PriceDisplay ht={ht} ttc={ttc} size="sm" />
      <StockBadge state={stock} quantity={qty} />
    </div>
  </div>
</a>
