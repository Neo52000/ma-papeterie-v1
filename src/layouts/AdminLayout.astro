---
import '@/styles/global.css';

export interface Props {
  title: string;
  email?: string;
}

const { title, email } = Astro.props;

interface NavItem {
  href: string;
  label: string;
}

const NAV: NavItem[] = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/devis', label: 'Devis B2B' },
  { href: '/admin/commandes', label: 'Commandes' },
  { href: '/admin/listes-scolaires', label: 'Listes scolaires' },
  { href: '/admin/produits', label: 'Produits' },
  { href: '/admin/notifications', label: 'Notifications' },
  { href: '/admin/cutover', label: 'Cutover' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/admin';
const isActive = (href: string): boolean => {
  if (href === '/admin') return pathname === '/admin';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Admin Ma Papeterie</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex min-h-screen flex-col bg-bg-soft">
    <header class="sticky top-0 z-30 border-b border-primary/10 bg-white">
      <div class="mx-auto flex h-14 max-w-7xl items-center gap-4 px-4 sm:px-6 lg:px-8">
        <a href="/admin" class="flex items-center gap-2">
          <span class="rounded-badge bg-primary px-2 py-0.5 text-xs font-semibold text-white"
            >ADMIN</span
          >
          <span class="font-display text-base font-semibold text-primary">Ma Papeterie</span>
        </a>
        <nav aria-label="Navigation admin" class="ml-6 hidden items-center gap-4 md:flex">
          {
            NAV.map((item) => {
              const active = isActive(item.href);
              return (
                <a
                  href={item.href}
                  aria-current={active ? 'page' : undefined}
                  class:list={[
                    'text-sm font-medium transition-colors hover:text-accent',
                    active ? 'text-accent' : 'text-primary/70',
                  ]}
                >
                  {item.label}
                </a>
              );
            })
          }
        </nav>
        <div class="ml-auto flex items-center gap-3 text-xs text-primary/60">
          {email && <span>{email}</span>}
          <a href="/" class="text-primary/60 hover:text-accent">← Site public</a>
        </div>
      </div>
      <nav
        aria-label="Navigation admin mobile"
        class="overflow-x-auto border-t border-primary/5 bg-white px-4 py-2 md:hidden"
      >
        <ul class="flex gap-3 text-xs">
          {
            NAV.map((item) => (
              <li class="flex-shrink-0">
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? 'page' : undefined}
                  class:list={[
                    'inline-flex items-center rounded-btn border px-3 py-1.5 transition-colors',
                    isActive(item.href)
                      ? 'border-accent bg-accent/10 text-accent'
                      : 'border-primary/15 bg-white text-primary/70 hover:border-accent/50',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-8 sm:px-6 lg:px-8">
      <slot />
    </main>

    <footer
      class="border-t border-primary/10 bg-white px-4 py-4 text-center text-xs text-primary/40 sm:px-6 lg:px-8"
    >
      Admin interne — Ma Papeterie · Données sensibles, ne pas partager.
    </footer>
  </body>
</html>
