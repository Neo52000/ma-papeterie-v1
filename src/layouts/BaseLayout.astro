---
import '@/styles/global.css';
import SEO from '@/components/seo/SEO.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';
import BackToTop from '@/components/ui/BackToTop';
import PwaInstallPrompt from '@/components/ui/PwaInstallPrompt';
import { organizationSchema } from '@/lib/schema';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article' | 'product';
  noindex?: boolean;
  jsonLd?: string[];
}

const { title, description, canonical, ogImage, ogType, noindex, jsonLd = [] } = Astro.props;
const seoJsonLd = [organizationSchema(), ...jsonLd];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#121c2a" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- DNS prefetch + connection priming for the two third parties touched
         by every page (Storefront API for cart, Supabase for catalogue). -->
    <link rel="preconnect" href="https://ma-papeterie52.myshopify.com" crossorigin />
    <link rel="preconnect" href="https://mgojmkzovqgpipybelrr.supabase.co" crossorigin />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      ogImage={ogImage}
      ogType={ogType}
      noindex={noindex}
      jsonLd={seoJsonLd}
    />
  </head>
  <body class="flex min-h-screen flex-col">
    <a href="#main-content" class="skip-link">Aller au contenu principal</a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <BackToTop client:idle />
    <PwaInstallPrompt client:idle />
  </body>
</html>
